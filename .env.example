# Required MCP API keys
# GitHub MCP server token (mapped to GITHUB_PERSONAL_ACCESS_TOKEN in .opencode/opencode.jsonc)
GITHUB_PAT=your_github_personal_access_token

# GitHub Project V2 automation token (set this value as repository secret PROJECT_V2_TOKEN)
PROJECT_V2_TOKEN=your_github_project_v2_token

# Required Discord webhook URLs (one per agent persona)
DISCORD_WEBHOOK_PLANNER=https://discord.com/api/webhooks/your-planner-webhook
DISCORD_WEBHOOK_ORCHESTRATOR=https://discord.com/api/webhooks/your-orchestrator-webhook
DISCORD_WEBHOOK_MINION=https://discord.com/api/webhooks/your-minion-webhook
DISCORD_WEBHOOK_REVIEWER=https://discord.com/api/webhooks/your-reviewer-webhook

# Required Discord bot token (used for slash command handling)
DISCORD_BOT_TOKEN=your_discord_bot_token

# Optional Discord routing context
DISCORD_CHANNEL_ID=your_discord_channel_id
