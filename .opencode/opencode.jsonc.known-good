{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "planner": {
      "description": "Analyzes GitHub issues, identifies target files using glob/grep, and generates atomic plan files in /agents/plans/",
      "mode": "primary",
      "model": "openrouter/google/gemini-3.1-pro-preview"
    },
    "orchestrator": {
      "description": "Routes tasks to specialized agents via the Matchmaker tool and spawns isolated worktree sessions",
      "mode": "primary",
      "model": "openrouter/google/gemini-3.1-pro-preview"
    },
    "minion": {
      "description": "Execution-focused agent that implements specific features or fixes within an isolated worktree",
      "mode": "subagent",
      "model": "openrouter/google/gemini-3.1-pro-preview"
    },
    "reviewer": {
      "description": "Performs automated PR analysis and triggers notifications for human-in-the-loop approval",
      "mode": "subagent",
      "model": "openrouter/google/gemini-3.1-pro-preview"
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
      }
    }
  },
  "permission": {
    "bash": {
      "git push": "deny",
      "git push *": "deny"
    }
  }
}
